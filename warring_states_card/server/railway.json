{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NITRO",
    "buildCommand": "npm run build",
    "startCommand": "node .output/server/index.mjs"
  },
  "deploy": {
    "region": "us-west1",
    "runtime": "node@18"
  },
  "environments": {
    "production": {
      "variables": {
        "NODE_ENV": "production",
        "CORS_ORIGIN": "https://warring-states-card.app"
      }
    }
  }
}